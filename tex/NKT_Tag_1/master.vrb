\frametitle{Rekursion}
	Was ist Rekursion?
	\begin{itemize}
		\item Methode, die sich selbt aufruft
		\item benötigt Rekursionsanker
		\item wenig code, jedoch häufig verwirrend
	\end{itemize}
\begin{lstlisting}
    static void recursiveCount(int n){
        System.out.println(n);
        if( n <= 0){
            return;
        }
        recursiveCount(n-1);
    }
\end{lstlisting}
