\frametitle{Referenzen}
	\begin{lstlisting}
	Person a = new Person();
	Person b = new Person();
    System.out.println(a == b);
	\end{lstlisting}
	Wird true oder false ausgegeben?
	\newline
	$\rightarrow$ Es wird false ausgegeben
	\begin{lstlisting}
	System.out.println(a);        //Person@7ad041f3
	System.out.println(b);        //Person@251a69d7 	
	\end{lstlisting}
